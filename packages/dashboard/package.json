{
  "name": "@timnoya/dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/index.ts"
  },
  "dependencies": {
    "bun-plugin-tailwind": "^0.1.2",
    "lucide-react": "^1.14.0",
    "react": "^19",
    "react-dom": "^19",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "ts-pattern": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bun": "latest"
  }
}
